{
    "name": "ejosterberg/opensalestax-prestashop",
    "description": "PrestaShop 8.x module — destination-based US sales tax via the self-hosted OpenSalesTax engine",
    "type": "prestashop-module",
    "license": "Apache-2.0 OR GPL-2.0-or-later",
    "keywords": [
        "prestashop",
        "prestashop8",
        "tax",
        "sales-tax",
        "us-tax",
        "opensalestax",
        "tax-calculation"
    ],
    "homepage": "https://github.com/ejosterberg/opensalestax-prestashop",
    "authors": [
        {
            "name": "Eric Osterberg",
            "email": "ejosterberg@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ejosterberg/opensalestax": "^0.2.0",
        "guzzlehttp/guzzle": "^7.8",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.59"
    },
    "autoload": {
        "psr-4": {
            "OpenSalesTax\\PrestaShop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenSalesTax\\PrestaShop\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@stan",
            "@cs",
            "@audit"
        ],
        "test": "phpunit",
        "stan": "phpstan analyse --no-progress",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "audit": "@composer audit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
